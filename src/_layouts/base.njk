<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8YX9WZEMJ1"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-G-8YX9WZEMJ1', {
      page_path: window.location.pathname,
    });
  </script>
  <!-- 스타일·스크립트 로드 -->
  <link rel="stylesheet" href="/assets/css/style.css" />
  <script src="/assets/js/main.js" defer></script>
</head>
<body>
  {% include "header.html" %}
  <main>
    {% include "ads-slot.html" %}
    {{ content | safe }}
  </main>
  {% include "footer.html" %}
  <script src="/assets/js/main.js" defer></script>
  {% if "ip" in page.url %}
  <script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js" defer></script>
  {% endif %}
  {% if "vat" in page.url %}
    <script src="/assets/js/vat.js" defer></script>
  {% endif %}
  {% if "convert" in page.url %}
    <script src="/assets/js/convert.js" defer></script>
  {% endif %}
  {% if "exchange" in page.url %}
    <script src="/assets/js/exchange.js" defer></script>
  {% endif %}
  {% if "ip" in page.url %}
    <script src="/assets/js/ip.js" defer></script>
  {% endif %}
</body>
</html>
